{
  "stage": "ML-M2",
  "model": {
    "vocab_size": 2048,
    "context_length": 128,
    "num_layers": 1,
    "d_model": 64,
    "num_attention_heads": 8,
    "num_key_value_heads": 8,
    "d_head": 8,
    "d_ffn": 256,
    "rms_norm_eps": 1e-5,
    "activation": "relu",
    "bias": false,
    "dropout": 0.0,
    "tie_word_embeddings": true
  },
  "training": {
    "seed": 20260713,
    "dtype": "fp32",
    "batch_size": 16,
    "learning_rate": 0.001,
    "weight_decay": 0.01,
    "grad_clip_norm": 1.0
  },
  "dataset": {
    "name": "TinyStories",
    "subset_examples": 100000,
    "validation_fraction": 0.02
  }
}

